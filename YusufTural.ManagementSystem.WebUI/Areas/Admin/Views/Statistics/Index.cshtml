@model Statistic
@{
    ViewData["Title"] = "İstatistik Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Genel İstatistikler</h1>
</div>

<section class="section">
    <div class="row">
        <div class="col-12">
            @if (Model == null)
            {
                <div class="card shadow-sm text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-bar-chart text-primary display-4"></i>
                        <h4 class="mt-3">İstatistik Verisi Bulunamadı</h4>
                        <p class="text-muted">Ana sayfadaki sayaçları aktif etmek için ilk kaydı oluşturun.</p>
                        <a asp-action="Create" class="btn btn-primary px-4">İlk Kaydı Oluştur</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center border-bottom">
                        <h5 class="card-title mb-0">Aktif Sayaç Verileri</h5>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm text-white">Verileri Düzenle</a>
                    </div>
                    <div class="card-body pt-3">
                        <div class="row g-4 text-center">
                            <div class="col-md-3">
                                <div class="p-3 border rounded shadow-sm">
                                    <h2 class="fw-bold text-primary">@Model.HappyCustomerCount</h2>
                                    <span class="text-secondary small fw-bold">Mutlu Müşteri</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 border rounded shadow-sm">
                                    <h2 class="fw-bold text-success">@Model.TransportedWaterAmount</h2>
                                    <span class="text-secondary small fw-bold">Taşınan Su Mik.</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 border rounded shadow-sm">
                                    <h2 class="fw-bold text-info">@Model.CompletedJobCount</h2>
                                    <span class="text-secondary small fw-bold">Tamamlanan İş</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 border rounded shadow-sm">
                                    <h2 class="fw-bold text-warning">@Model.YearsOfExperience</h2>
                                    <span class="text-secondary small fw-bold">Yıllık Deneyim</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>