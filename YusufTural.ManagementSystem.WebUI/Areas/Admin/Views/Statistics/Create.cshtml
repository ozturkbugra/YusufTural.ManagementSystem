@model Statistic
@{
    ViewData["Title"] = "Yeni İstatistik Kaydı";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>İstatistik Tanımla</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">İstatistikler</a></li>
            <li class="breadcrumb-item active">Yeni Kayıt</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Genel Sayaç Bilgileri</h5>
                    <p class="card-subtitle text-muted small mb-4">Ana sayfada görünecek olan başarı rakamlarını buradan tanımlayabilirsiniz.</p>

                    <form asp-action="Create" method="post" class="row g-3">
                        
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Mutlu Müşteri Sayısı</label>
                            <input type="number" asp-for="HappyCustomerCount" class="form-control" placeholder="Örn: 1500+" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Taşınan Su Miktarı</label>
                                <input type="number" asp-for="TransportedWaterAmount" class="form-control" placeholder="Örn: 50.000 Ton" required>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Tamamlanan İş Sayısı</label>
                                    <input type="number" asp-for="CompletedJobCount" class="form-control" placeholder="Örn: 2400" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Yıllık Deneyim</label>
                                        <input type="number" asp-for="YearsOfExperience" class="form-control" placeholder="Örn: 15 Yıl" required>
                                        </div>

                                        <div class="col-12 mt-4 text-end border-top pt-3">
                                            <a asp-action="Index" class="btn btn-secondary me-2">Vazgeç</a>
                                            <button type="submit" class="btn btn-primary px-4">
                                                <i class="bi bi-save me-1"></i> İstatistikleri Yayınla
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                       
                    </div>
                </section>