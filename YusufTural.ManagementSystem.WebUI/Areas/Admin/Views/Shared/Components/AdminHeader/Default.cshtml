<header class="header">
    <div class="header-left">
        <button class="sidebar-toggle" title="Menüyü Aç/Kapat">
            <span class="menu-lines">
                <span></span>
                <span></span>
                <span></span>
            </span>
        </button>

        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="header-brand">
            <span class="header-logo">
            </span>
            <span class="header-context">
                <strong class="header-context-title">Admin Panel</strong>
            </span>
        </a>
    </div>

    <div class="header-right">
        <div class="header-actions-desktop">
            
            <div class="header-search-wrap">
                <div class="search-form">
                    <i class="bi bi-search search-icon"></i>
                    <input type="search" class="sidebar-search-input" placeholder="Ara..." autocomplete="off">
                    <kbd class="search-shortcut">/</kbd>
                </div>
            </div>

            <div class="mobile-search">
                <div class="search-form">
                    <input type="search" class="sidebar-search-input" placeholder="Ara..." autocomplete="off">
                    <button type="button"><i class="bi bi-search"></i></button>
                </div>
            </div>

            <button class="header-action theme-toggle" title="Tema Değiştir">
                <i class="ph-light ph-moon-stars theme-icon-dark"></i>
                <i class="ph-light ph-sun theme-icon-light"></i>
            </button>

            <div class="header-action-wrap dropdown user-dropdown">
                <button class="dropdown-toggle user-trigger" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="~/admin/assets/img/profile-img.webp" alt="User" class="user-avatar">
                        <div class="user-brief">
                            <span class="user-name">@User.Identity.Name</span>
                            <span class="user-role">Yönetici</span>
                        </div>
                    </button>

                    <div class="dropdown-menu dropdown-menu-end user-menu">
                        <div class="user-menu-header">
                            <img src="~/admin/assets/img/profile-img.webp" alt="User" class="user-menu-avatar">
                                <div class="user-menu-info">
                                    <div class="user-menu-name">@User.Identity.Name</div>
                                    <div class="user-menu-email">Sistem Yöneticisi</div>
                                </div>
                            </div>
                            <div class="user-menu-body">
                                <a class="user-menu-item" asp-area="Admin" asp-controller="AppUser" asp-action="Index">
                                    <i class="bi bi-person"></i>
                                    <span>Profilim</span>
                                </a>
                                <a class="user-menu-item" asp-area="Admin" asp-controller="SiteInformation" asp-action="Index">
                                    <i class="bi bi-gear"></i>
                                    <span>Site Ayarları</span>
                                </a>
                            </div>
                            <div class="user-menu-footer">
                                <a class="user-menu-logout" asp-area="Admin" asp-controller="Login" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Güvenli Çıkış</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>