
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Dashboard</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="card-title text-primary">Hoş Geldin Aga! 👋</h5>
                    <p class="mb-0">
                        Şu an <strong>Yusuf Tural Yönetim Paneli</strong> iskeleti üzerindesin.
                        Giriş sistemi, yetkilendirme ve modüler Layout yapısı başarıyla çalışıyor.
                    </p>
                    <hr class="my-4 text-muted">
                    <div class="alert alert-info bg-info-light border-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Şu an giriş yapan kullanıcı: <strong>@User.Identity.Name</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
