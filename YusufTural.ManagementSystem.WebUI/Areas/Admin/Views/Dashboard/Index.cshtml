@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Genel Bakış</h1>
</div>

<section class="section dashboard">
    <div class="row">
        <div class="col-xxl-4 col-md-6">
            <div class="card info-card sales-card shadow-sm border-start border-primary border-4">
                <div class="card-body">
                    <h5 class="card-title">Bugün <span>| Ziyaretçi</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-primary-light text-primary">
                            <i class="bi bi-people"></i>
                        </div>
                        <div class="ps-3">
                            <h6>@ViewBag.DailyCount</h6>
                            <span class="text-muted small pt-2">Anlık veri</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xxl-4 col-md-6">
            <div class="card info-card revenue-card shadow-sm border-start border-success border-4">
                <div class="card-body">
                    <h5 class="card-title">Bu Ay <span>| Toplam</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-success-light text-success">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <div class="ps-3">
                            <h6>@ViewBag.MonthlyCount</h6>
                            <span class="text-muted small pt-2 ps-1">Cari Ay</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xxl-4 col-xl-12">
            <div class="card info-card customers-card shadow-sm border-start border-warning border-4">
                <div class="card-body">
                    <h5 class="card-title">Bu Yıl <span>| Toplam</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-warning-light text-warning">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>
                        <div class="ps-3">
                            <h6>@ViewBag.YearlyCount</h6>
                            <span class="text-muted small pt-2 ps-1">Cari Yıl</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Zirve Yapan 10 Gün</h5>
                    <div id="topDaysChart"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">En Popüler 3 Ay</h5>
                    <div id="topMonthsChart"></div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/admin/assets/vendor/apexcharts/apexcharts.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Top 10 Days Bar Chart
            new ApexCharts(document.querySelector("#topDaysChart"), {
                series: [{
                    name: 'Ziyaret Sayısı',
                    data: @Html.Raw(Json.Serialize(ViewBag.TopDaysValues))
                }],
                chart: { type: 'bar', height: 350, toolbar: { show: false } },
                plotOptions: { bar: { borderRadius: 4, horizontal: true } },
                colors: ['#3b82f6'],
                xaxis: { categories: @Html.Raw(Json.Serialize(ViewBag.TopDaysLabels)) }
            }).render();

            // Top 3 Months Donut Chart
            new ApexCharts(document.querySelector("#topMonthsChart"), {
                series: @Html.Raw(Json.Serialize(ViewBag.TopMonthsValues)),
                chart: { type: 'donut', height: 350 },
                labels: @Html.Raw(Json.Serialize(ViewBag.TopMonthsLabels)),
                colors: ['#2ecc71', '#f1c40f', '#3498db'],
                legend: { position: 'bottom' }
            }).render();
        });
    </script>
}