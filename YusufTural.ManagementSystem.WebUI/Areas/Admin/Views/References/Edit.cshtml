@model Reference
@{
    ViewData["Title"] = "Referans Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Referansı Güncelle</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Referanslar</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Kayıt Detayları</h5>
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="LogoUrl" />

                        <div class="row g-3">
                            <div class="col-12 text-center mb-3">
                                <label class="form-label d-block text-start fw-bold">Mevcut Logo</label>
                                <div class="p-4 border rounded d-inline-block shadow-sm" style="background-color: rgba(128, 128, 128, 0.05);">
                                    <img id="editLogoPreview" src="@Model.LogoUrl" class="img-fluid" style="max-height: 120px; object-fit: contain;">
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-bold">Logoyu Değiştir</label>
                                <input type="file" name="logoImage" class="form-control" accept="image/*" onchange="previewImage(this, 'editLogoPreview')">
                                <div class="form-text">Değişiklik yapılmayacaksa boş bırakınız.</div>
                            </div>

                            <div class="col-12 mt-4 pt-3 border-top text-end">
                                <a asp-action="Index" class="btn btn-secondary me-2">Vazgeç</a>
                                <button type="submit" class="btn btn-warning text-white px-4">Güncellemeyi Kaydet</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}