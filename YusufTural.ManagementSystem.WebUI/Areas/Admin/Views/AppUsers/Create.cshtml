@model AppUser
@{
    ViewData["Title"] = "Yeni Yönetici Tanımla";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Yönetici Ekle</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Yönetici Ayarları</a></li>
            <li class="breadcrumb-item active">Yeni Kayıt</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Erişim Bilgilerini Belirleyiniz</h5>
                    <form asp-action="Create" method="post" class="row g-3">
                        
                        <div class="col-12">
                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" asp-for="Username" class="form-control" placeholder="Örn: ytural" required>
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-bold">Şifre</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                                    <input type="password" asp-for="Password" class="form-control" placeholder="Güçlü bir şifre giriniz" required>
                                    </div>
                                    <div class="form-text">Şifreniz sistem güvenliği için şifrelenerek saklanacaktır.</div>
                                </div>

                                <div class="col-12 mt-4 text-end border-top pt-3">
                                    <a asp-action="Index" class="btn btn-secondary me-2">İptal</a>
                                    <button type="submit" class="btn btn-primary px-4">
                                        <i class="bi bi-person-check me-1"></i> Hesabı Oluştur
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>