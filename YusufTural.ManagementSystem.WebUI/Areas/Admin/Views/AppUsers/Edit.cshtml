@model AppUser
@{
    ViewData["Title"] = "Yönetici Bilgilerini Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Hesabı Düzenle</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Yönetici Ayarları</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Kayıt Güncelleme</h5>
                    <form asp-action="Edit" method="post" class="row g-3">
                        <input type="hidden" asp-for="Id" />

                        <div class="col-12">
                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" asp-for="Username" class="form-control" required>
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-bold">Yeni Şifre</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                                    <input type="password" asp-for="Password" class="form-control">
                                    </div>
                                    <div class="form-text text-warning"><i class="bi bi-exclamation-circle me-1"></i> Mevcut şifreyi değiştirmek istemiyorsanız aynı şifreyi giriniz.</div>
                                </div>

                                <div class="col-12 mt-4 text-end border-top pt-3">
                                    <a asp-action="Index" class="btn btn-secondary me-2">Vazgeç</a>
                                    <button type="submit" class="btn btn-warning text-white px-4">
                                        <i class="bi bi-save me-1"></i> Değişiklikleri Kaydet
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>