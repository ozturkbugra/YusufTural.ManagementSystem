@model Testimonial
@{
    ViewData["Title"] = "Müşteri Yorumunu Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Yorumu Güncelle</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Yorumlar</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-10">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Yorum Detaylarını Güncelleyiniz</h5>
                    
                    <form asp-action="Edit" method="post" class="row g-3">
                        <input type="hidden" asp-for="Id" />

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Müşteri Adı Soyadı</label>
                            <input type="text" asp-for="FullName" class="form-control" placeholder="Örn: Ahmet Yılmaz" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Müşteri Ünvanı / Şirketi</label>
                                <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Şantiye Şefi">
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-bold">Müşteri Yorumu</label>
                                    <textarea asp-for="Comment" class="form-control" rows="5" placeholder="Müşterinin geri bildirimini buraya yazınız..." required></textarea>
                                </div>

                                <div class="col-12 mt-4 text-end border-top pt-3">
                                    <a asp-action="Index" class="btn btn-secondary me-2">Vazgeç</a>
                                    <button type="submit" class="btn btn-warning text-white px-4">
                                        <i class="bi bi-check-lg me-1"></i> Değişiklikleri Uygula
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>