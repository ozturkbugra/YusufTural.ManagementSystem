@model List<Faq>
@{
    ViewData["Title"] = "Sıkça Sorulan Sorular";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Sıkça Sorulan Sorular</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Sıkça Sorulan Sorular</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-12">
            <div class="card overflow-auto shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title">Soru ve Cevap Listesi</h5>
                        <p class="card-subtitle text-muted small">Sistemdeki tüm kayıtları buradan yönetebilir, yeni soru-cevap ekleyebilirsiniz.</p>
                    </div>
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i> Yeni Soru Ekle
                    </a>
                </div>
                <div class="card-body">
                    <table class="table table-hover datatable" id="faqTable">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 35%;">Soru</th>
                                <th scope="col" style="width: 45%;">Cevap Özeti</th>
                                <th scope="col" data-sortable="false" class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.Question</strong></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Answer))
                                        {
                                            @if (item.Answer.Length > 80)
                                            {
                                                @Html.Raw(item.Answer.Substring(0, 80))
                                            
                                                <span>...</span>
                                            }
                                            else
                                            {
                                                @Html.Raw(item.Answer)
                                            }
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm btn-outline-warning" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                                   class="btn btn-icon btn-sm btn-outline-danger"
                                                   title="Sil"
                                                   onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('faqTable')) {
                new simpleDatatables.DataTable('#faqTable', {
                    perPage: 10,
                    labels: {
                        placeholder: "Soru ara...",
                        perPage: "kayıt göster",
                        noRows: "Eşleşen kayıt bulunamadı.",
                        info: "{rows} kayıttan {start} - {end} arası gösteriliyor"
                    }
                });
            }
        });
    </script>
}