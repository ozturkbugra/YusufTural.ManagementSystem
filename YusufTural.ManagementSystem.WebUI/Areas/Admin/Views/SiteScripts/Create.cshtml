@model SiteScript
@{
    ViewData["Title"] = "Yeni Script Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Yeni Script Tanımla</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Scriptler</a></li>
            <li class="breadcrumb-item active">Ekle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="card shadow-sm">
        <div class="card-body pt-3">
            <form asp-action="Create" method="post" class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-bold">Script Başlığı (Açıklayıcı bir ad giriniz)</label>
                    <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Google Analytics 4" required>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Pozisyon</label>
                        <select asp-for="Position" class="form-select" required>
                            <option value="1">Head (Üst Kısım)</option>
                            <option value="2">Body Start (Gövde Başlangıcı)</option>
                            <option value="3">Footer (Alt Kısım)</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-bold">Script İçeriği (&lt;script&gt; etiketleri dahil)</label>
                        <textarea asp-for="Content" class="form-control" rows="8"
                                  style="font-family: 'JetBrains Mono', monospace; font-size: 13px; background-color: rgba(128,128,128,0.05);"
                                  placeholder="Kodu buraya yapıştırınız..."></textarea>
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                <label class="form-check-label fw-bold">Script Yayınlansın Mı?</label>
                            </div>
                        </div>

                        <div class="col-12 mt-4 text-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary me-2">İptal</a>
                            <button type="submit" class="btn btn-primary px-4">Scripti Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>