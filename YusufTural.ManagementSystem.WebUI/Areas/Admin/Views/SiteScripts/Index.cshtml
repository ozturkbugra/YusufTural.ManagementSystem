@model List<SiteScript>
@{
    ViewData["Title"] = "Script Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Script Yönetimi</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Panel</a></li>
            <li class="breadcrumb-item active">Scriptler</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm overflow-auto">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title mb-0">Site Kod Parçacıkları</h5>
                        <p class="card-subtitle text-muted small">Analytics, Pixel veya Canlı Destek kodlarını buradan yönetebilirsiniz.</p>
                    </div>
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="bi bi-code-slash me-1"></i> Yeni Script Ekle
                    </a>
                </div>
                <div class="card-body pt-3">
                    <table class="table table-hover datatable" id="scriptTable">
                        <thead>
                            <tr>
                                <th scope="col">Script Başlığı</th>
                                <th scope="col">Pozisyon</th>
                                <th scope="col" class="text-center">Durum</th>
                                <th scope="col" data-sortable="false" class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.Title</strong></td>
                                    <td>
                                        <span class="badge border text-secondary border-secondary">
                                            @(item.Position == 1 ? "Head" : (item.Position == 2 ? "Body Start" : "Footer"))
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                            @(item.IsActive ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            @if (item.IsActive)
                                            {
                                                <a asp-action="ChangeStatus" asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-danger" title="Pasife Al"
                                                       onclick="return confirm('Bu scripti pasif duruma getirmek istediğinize emin misiniz?')">
                                                    <i class="bi bi-eye-slash"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-action="ChangeStatus" asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-success" title="Aktif Et">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('scriptTable')) {
                new simpleDatatables.DataTable('#scriptTable', {
                    perPage: 10,
                    labels: {
                        placeholder: "Ara...",
                        perPage: "kayıt göster",
                        noRows: "Kayıtlı script bulunamadı.",
                        info: "{rows} kayıttan {start} - {end} arası gösteriliyor"
                    }
                });
            }
        });
    </script>
}