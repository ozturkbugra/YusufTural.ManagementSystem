@model Vehicle
@{
    ViewData["Title"] = "Araç Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Araç Bilgilerini Güncelle</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Filo Yönetimi</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body pt-3">
                    <h5 class="card-title">Kayıt Detayları</h5>
                    
                    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-3">
                        @* Gizli Alanlar *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        @* Mevcut Görsel Önizleme *@
                        <div class="col-12 text-center mb-3">
                            <label class="form-label d-block text-start fw-bold">Mevcut Araç Görseli</label>
                            <div class="p-2 border rounded d-inline-block shadow-sm" style="background-color: rgba(128,128,128,0.05);">
                                <img id="editVehiclePreview" src="@Model.ImageUrl" class="img-fluid rounded" style="max-height: 250px; object-fit: contain;">
                            </div>
                        </div>

                        @* Görsel Yükleme *@
                        <div class="col-12">
                            <label class="form-label fw-bold">Görseli Değiştir</label>
                            <input type="file" name="vehicleImage" class="form-control" accept="image/*" onchange="previewImage(this, 'editVehiclePreview')">
                            <div class="form-text">Yeni bir görsel seçmediğiniz sürece mevcut görsel korunacaktır.</div>
                        </div>

                        @* Açıklama *@
                        <div class="col-12">
                            <label class="form-label fw-bold">Araç Açıklaması / Teknik Özellikler</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Örn: Mercedes-Benz Axor, 2024 model, 25 ton kapasiteli..."></textarea>
                        </div>

                        @* Butonlar *@
                        <div class="col-12 mt-4 text-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary me-2">Vazgeç</a>
                            <button type="submit" class="btn btn-warning text-white px-4">
                                <i class="bi bi-arrow-clockwise me-1"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* Yardımcı Bilgi Kartı *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-start border-warning border-4">
                <div class="card-body pt-3">
                    <h5 class="card-title fw-bold text-warning"><i class="bi bi-exclamation-triangle me-1"></i> Hatırlatma</h5>
                    <p class="small text-muted">
                        Yeni bir araç görseli yüklediğinizde, eski görsel sunucudan otomatik olarak silinecektir. Bu sayede dosya kirliliğinin önüne geçmiş oluruz.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}