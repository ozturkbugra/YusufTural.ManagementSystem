@model List<Vehicle>
@{
    ViewData["Title"] = "Araç Filosu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Filo Yönetimi</h1>
</div>

<section class="section">
    <div class="card shadow-sm overflow-auto">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Araç Listesi</h5>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Yeni Araç Ekle
            </a>
        </div>
        <div class="card-body pt-3">
            <table class="table table-hover datatable" id="vehicleTable">
                <thead>
                    <tr>
                        <th style="width: 100px;">Görsel</th>
                        <th>Açıklama</th>
                        <th class="text-center" data-sortable="false">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.ImageUrl" class="rounded border" style="width: 60px; height: 45px; object-fit: cover;">
                            </td>
                            <td class="small">@item.Description</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu aracı filodan silmek istediğinize emin misiniz?')"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('vehicleTable')) {
                new simpleDatatables.DataTable('#vehicleTable', {
                    labels: { placeholder: "Ara...", perPage: "kayıt", noRows: "Kayıt bulunamadı.", info: "{rows} kayıttan {start}-{end} arası" }
                });
            }
        });
    </script>
}