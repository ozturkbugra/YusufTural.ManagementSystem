@model List<Service>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Hizmet Yönetimi</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Hizmetler</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-12">
            <div class="card overflow-auto">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title">Hizmet Listesi</h5>
                        <p class="card-subtitle text-muted small">Sistemde kayıtlı olan tüm hizmetleri buradan yönetebilirsin aga.</p>
                    </div>
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i> Yeni Hizmet Ekle
                    </a>
                </div>
                <div class="card-body">
                    <table class="table table-hover datatable" id="servicesTable">
                        <thead>
                            <tr>
                                <th scope="col">Görsel</th>
                                <th scope="col">Hizmet Adı</th>
                                <th scope="col">Kısa Açıklama</th>
                                <th scope="col" data-sortable="false" class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="table-user">
                                            <img src="@item.ImageUrl" alt="@item.Title" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;">
                                        </div>
                                    </td>
                                    <td><strong>@item.Title</strong></td>
                                    <td>
                                        @if (item.ShortDescription.Length > 60)
                                        {
                                            @item.ShortDescription.Substring(0, 60)
                                        
                                            <span>...</span>
                                        }
                                        else
                                        {
                                            @item.ShortDescription
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm btn-outline-warning" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                                   class="btn btn-icon btn-sm btn-outline-danger"
                                                   title="Sil"
                                                   onclick="return confirm('Bu hizmeti ve sunucudaki görselini silmek istediğine emin misin aga?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Eğer datatable sınıfı otomatik çalışmazsa manuel tetikliyoruz
            if (document.getElementById('servicesTable')) {
                new simpleDatatables.DataTable('#servicesTable', {
                    perPage: 10,
                    labels: {
                        placeholder: "Hizmet ara...",
                        perPage: "kayıt göster",
                        noRows: "Hizmet bulunamadı aga!",
                        info: "{rows} kayıttan {start} - {end} arası gösteriliyor"
                    }
                });
            }
        });
    </script>
}
