@model Service
@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Yeni Hizmet Oluştur</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Hizmetler</a></li>
            <li class="breadcrumb-item active">Ekle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <form asp-action="Create" method="post" enctype="multipart/form-data" id="serviceForm">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm h-100">
                    <div class="card-body pt-3">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold">Hizmet Başlığı</label>
                                <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Özel Yazılım Geliştirme" required>
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-bold">Kısa Açıklama (Liste ve Kartlarda Görünür)</label>
                                    <textarea asp-for="ShortDescription" class="form-control" rows="3" placeholder="Hizmetin kısa özeti..."></textarea>
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-bold">Hizmet Detayları (Uzun Açıklama)</label>
                                    <div id="quillEditor" style="height: 300px;">
                                        <p>Hizmetin tüm detaylarını buraya yazabilirsin aga...</p>
                                    </div>
                                    <input type="hidden" asp-for="LongDescription" id="longDescriptionInput" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-transparent"><h5 class="card-title mb-0">Hizmet Görseli</h5></div>
                        <div class="card-body pt-3">
                            <div class="mb-3">
                                <label class="form-label small text-muted">Kapak Fotoğrafı Seç</label>
                                <input type="file" name="serviceImage" class="form-control" accept="image/*" onchange="previewImage(this, 'serviceImgPreview')" required>
                                <div class="mt-3 text-center">
                                    <img id="serviceImgPreview" src="#" class="img-fluid rounded d-none border" style="max-height: 200px;">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-body pt-3">
                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                                <i class="bi bi-save me-1"></i> Hizmeti Yayınla
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Listeye Dön</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </section>

    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Quill'i başlatıyoruz (Attığın dosyadaki snow temasıyla)
                var quill = new Quill('#quillEditor', {
                    theme: 'snow',
                    modules: {
                        toolbar: [
                            [{ 'header': [1, 2, 3, false] }],
                            ['bold', 'italic', 'underline', 'strike'],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            ['link', 'image'],
                            ['clean']
                        ]
                    }
                });

                // Form gönderilmeden önce Quill içeriğini gizli inputa basıyoruz
                var form = document.getElementById('serviceForm');
                form.onsubmit = function() {
                    var longDescription = document.querySelector('#longDescriptionInput');
                    longDescription.value = quill.root.innerHTML;
                };
            });

            // Görsel Önizleme Fonksiyonu
            function previewImage(input, previewId) {
                const preview = document.getElementById(previewId);
                if (input.files && input.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        preview.src = e.target.result;
                        preview.classList.remove('d-none');
                    }
                    reader.readAsDataURL(input.files[0]);
                }
            }
        </script>
    }

