@model SiteInformation
@{
    ViewData["Title"] = "Site Bilgilerini Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Site Ayarlarını Güncelle</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Site Bilgileri</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<section class="section">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        
        @* Mevcut dosya yollarını hidden tutuyoruz ki değişmeyenler kaybolmasın *@
        <input type="hidden" asp-for="Logo" />
        <input type="hidden" asp-for="Favicon" />
        <input type="hidden" asp-for="BigFavicon" />
        <input type="hidden" asp-for="VideoUrl" />
        <input type="hidden" asp-for="BigImageUrl" />

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card h-100 shadow-sm">
                    <div class="card-header bg-transparent border-bottom">
                        <h5 class="card-title mb-0">Genel & SEO Yapılandırması</h5>
                    </div>
                    <div class="card-body pt-3">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Site Adı</label>
                                <input type="text" asp-for="Name" class="form-control" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Slogan</label>
                                    <input type="text" asp-for="Slogan" class="form-control">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-bold">Slogan Açıklaması</label>
                                        <textarea asp-for="SloganDescription" class="form-control" rows="2"></textarea>
                                    </div>
                            
                                    <div class="col-12 mt-4">
                                        <h6 class="text-primary fw-bold"><i class="bi bi-search me-1"></i> SEO Ayarları</h6>
                                        <hr class="mt-1">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">SEO Başlığı</label>
                                        <input type="text" asp-for="SeoTitle" class="form-control">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">SEO Anahtar Kelimeler</label>
                                            <input type="text" asp-for="SeoKeyword" class="form-control">
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label fw-bold">SEO Açıklaması</label>
                                                <textarea asp-for="SeoDescription" class="form-control" rows="3"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <div class="card mb-4 shadow-sm">
                                    <div class="card-header bg-transparent border-bottom">
                                        <h5 class="card-title mb-0">Görsel Ayarları</h5>
                                    </div>
                                    <div class="card-body pt-3">
                                        @* Logo Alanı *@
                                        <div class="mb-4">
                                            <label class="form-label fw-bold">Ana Logo</label>
                                            @if (!string.IsNullOrEmpty(Model.Logo))
                                            {
                                                <div class="mb-2 d-flex align-items-center justify-content-between p-2 border rounded bg-light">
                                                    <img id="logoPreview" src="@Model.Logo" alt="Mevcut Logo" style="max-height: 60px;">
                                                    <div class="form-check form-switch mb-0">
                                                        <input class="form-check-input" type="checkbox" name="deleteLogo" value="true" id="deleteLogo">
                                                        <label class="form-check-label text-danger small" for="deleteLogo">Kaldır</label>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="mb-2"><img id="logoPreview" src="/site/assets/img/no-image.png" class="img-thumbnail" style="max-height: 60px;"></div>
                                            }
                                            <input type="file" name="logoFile" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this, 'logoPreview')">
                                        </div>

                                        @* Arka Plan Alanı *@
                                        <div class="mb-4">
                                            <label class="form-label fw-bold">Arka Plan (Hero)</label>
                                            <div class="mb-2">
                                                <img id="bigImagePreview" src="@Model.BigImageUrl" class="img-thumbnail" style="max-height: 100px; width: 100%; object-fit: cover;">
                                            </div>
                                            <input type="file" name="bigImageFile" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this, 'bigImagePreview')">
                                        </div>

                                        @* Faviconlar *@
                                        <div class="row g-2 mb-4">
                                            <div class="col-6">
                                                <label class="form-label small fw-bold">Favicon (16x16)</label>
                                                <div class="text-center p-2 border rounded mb-2"><img id="faviconPreview" src="@Model.Favicon" style="width: 16px; height: 16px;"></div>
                                                <input type="file" name="faviconFile" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this, 'faviconPreview')">
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label small fw-bold">Apple Icon (32x32)</label>
                                                <div class="text-center p-2 border rounded mb-2"><img id="bigFaviconPreview" src="@Model.BigFavicon" style="width: 32px; height: 32px;"></div>
                                                <input type="file" name="bigFaviconFile" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this, 'bigFaviconPreview')">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card shadow-sm">
                                    <div class="card-header bg-transparent border-bottom">
                                        <h5 class="card-title mb-0">Tanıtım Videosu</h5>
                                    </div>
                                    <div class="card-body pt-3">
                                        @if (!string.IsNullOrEmpty(Model.VideoUrl))
                                        {
                                            <div class="alert alert-info py-2 px-3 small mb-3 d-flex align-items-center justify-content-between">
                                                <span><i class="bi bi-play-circle me-1"></i> Video Yüklü</span>
                                                <div class="form-check form-switch mb-0">
                                                    <input class="form-check-input" type="checkbox" name="deleteVideo" value="true" id="deleteVideo">
                                                    <label class="form-check-label text-danger" for="deleteVideo">Sil</label>
                                                </div>
                                            </div>
                                        }
                                        <input type="file" name="videoFile" class="form-control form-control-sm" accept="video/mp4,video/*">
                        
                                        <div class="d-grid gap-2 mt-4">
                                            <button type="submit" class="btn btn-warning text-white py-2 fw-bold">
                                                <i class="bi bi-check-circle me-1"></i> Ayarları Güncelle
                                            </button>
                                            <a asp-action="Index" class="btn btn-light py-2">İptal</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </section>

                @section Scripts {
                    <script>
                        function previewImage(input, previewId) {
                            const preview = document.getElementById(previewId);
                            if (input.files && input.files[0]) {
                                const reader = new FileReader();
                                reader.onload = function (e) {
                                    preview.src = e.target.result;
                                };
                                reader.readAsDataURL(input.files[0]);
                            }
                        }
                    </script>
                }