@model List<SiteInformation>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Site Genel Bilgileri</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Site Bilgileri</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title">Yönetim Paneli Ayarları</h5>
                        @if (!Model.Any())
                        {
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Yeni Kayıt Oluştur
                            </a>
                        }
                    </div>

                    <p class="text-muted small">Sitenin SEO başlıklarını, logolarını ve tanıtım videosunu buradan takip edebilirsin aga.</p>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Medya</th>
                                    <th>Site Adı</th>
                                    <th>Slogan</th>
                                    <th>SEO Başlığı</th>
                                    <th>Video Durumu</th>
                                    <th class="text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <img src="@item.Logo" alt="Logo" class="rounded border" style="width: 40px; height: 40px; object-fit: cover;" title="Ana Logo">
                                                <img src="@item.Favicon" alt="Fav" class="rounded border" style="width: 40px; height: 40px; object-fit: cover;" title="Favicon">
                                            </div>
                                        </td>
                                        <td><strong>@item.Name</strong></td>
                                        <td><span class="text-truncate d-inline-block" style="max-width: 150px;">@item.Slogan</span></td>
                                        <td><span class="badge bg-info-light text-info">@item.SeoTitle</span></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.VideoUrl))
                                            {
                                                <span class="badge bg-success-light text-success">
                                                    <i class="bi bi-check-circle-fill me-1"></i> Video Mevcut
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-light text-danger">
                                                    <i class="bi bi-x-circle-fill me-1"></i> Video Yok
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Düzenle">
                                                <i class="bi bi-pencil-square"></i> Düzenle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

