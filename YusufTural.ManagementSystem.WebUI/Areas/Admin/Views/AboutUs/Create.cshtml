@model AboutUs
@{
    ViewData["Title"] = "Yeni Hakkımızda Yazısı";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Kurumsal Bilgi Ekle</h1>
</div>

<section class="section">
    <form asp-action="Create" method="post" enctype="multipart/form-data" id="aboutCreateForm">
        <div class="card">
            <div class="card-body pt-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Kurumsal Görsel</label>
                        <input type="file" name="aboutImage" class="form-control" accept="image/*" onchange="previewImage(this, 'aboutPreview')" required>
                        <img id="aboutPreview" src="#" class="mt-3 img-thumbnail d-none" style="max-height: 200px;">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">Hakkımızda Yazısı</label>
                        <div id="quillEditor" style="height: 350px;"></div>
                        <input type="hidden" asp-for="Description" id="descInput" />
                    </div>
                    <div class="col-12 mt-4 text-end">
                        <button type="submit" class="btn btn-primary px-5">Kaydet</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        var quill = new Quill('#quillEditor', { theme: 'snow' });
        document.getElementById('aboutCreateForm').onsubmit = function() {
            document.getElementById('descInput').value = quill.root.innerHTML;
        };
        function previewImage(input, id) {
            const preview = document.getElementById(id);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { preview.src = e.target.result; preview.classList.remove('d-none'); }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}