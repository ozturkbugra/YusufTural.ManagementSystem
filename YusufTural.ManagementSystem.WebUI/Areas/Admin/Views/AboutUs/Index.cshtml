@model AboutUs
@{
    ViewData["Title"] = "Hakkımızda Genel Bakış";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Hakkımızda Yönetimi</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Hakkımızda</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            @if (Model == null)
            {
                <div class="card shadow-sm border-light text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-info-circle text-warning display-1"></i>
                        <h3 class="mt-3">Henüz Hakkımızda Bilgisi Eklenmemiş!</h3>
                        <p class="text-muted">Sitenin kurumsal kimliğini oluşturmak için ilk kaydı şimdi ekleyebilirsin aga.</p>
                        <a asp-action="Create" class="btn btn-primary px-4 py-2">
                            <i class="bi bi-plus-circle me-1"></i> İlk Kaydı Oluştur
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Mevcut Kurumsal Bilgiler</h5>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm text-white">
                            <i class="bi bi-pencil-square me-1"></i> Bilgileri Düzenle
                        </a>
                    </div>
                    <div class="card-body pt-3">
                        <div class="row align-items-center">
                            <div class="col-md-4 text-center">
                                <img src="@Model.ImageUrl" alt="Hakkımızda Görseli" class="img-fluid rounded border shadow-sm" style="max-height: 250px;">
                            </div>
                            <div class="col-md-8">
                                <h6 class="fw-bold text-primary border-bottom pb-2">Tanıtım Yazısı Önizleme</h6>
                                <div class="text-muted mt-3">
                                    @Html.Raw(Model.Description.Length > 500 ? Model.Description.Substring(0, 500) + "..." : Model.Description)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>