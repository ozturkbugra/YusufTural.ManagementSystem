<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>@ViewData["Title"] - @ViewData["SiteName"]</title>
    <meta name="description" content="@ViewData["SeoDescription"]">
    <meta name="keywords" content="@ViewData["SeoKeyword"]">

    <link href="@ViewData["Favicon"]" rel="icon">
    <link href="@ViewData["BigFavicon"]" rel="apple-touch-icon">

    <link href="https://fonts.googleapis.com" rel="preconnect">
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link href="~/site/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
        <link href="~/site/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
            <link href="~/site/assets/vendor/aos/aos.css" rel="stylesheet">
                <link href="~/site/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
                    <link href="~/site/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

                        <link href="~/site/assets/css/main.css" rel="stylesheet">
  
                            @await RenderSectionAsync("Styles", required: false)
                        </head>

                        <body class="@ViewData["BodyClass"]">

                            @await Component.InvokeAsync("SiteHeader")

                            <main class="main">
                                @RenderBody()
                            </main>

                            @await Component.InvokeAsync("SiteFooter")

                            <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
                                <i class="bi bi-arrow-up-short"></i>
                            </a>

                            <div id="preloader"></div>

                            <script src="~/site/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
                            <script src="~/site/assets/vendor/php-email-form/validate.js"></script>
                            <script src="~/site/assets/vendor/aos/aos.js"></script>
                            <script src="~/site/assets/vendor/glightbox/js/glightbox.min.js"></script>
                            <script src="~/site/assets/vendor/purecounter/purecounter_vanilla.js"></script>
                            <script src="~/site/assets/vendor/swiper/swiper-bundle.min.js"></script>
                            <script src="~/site/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
                            <script src="~/site/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>

                            <script src="~/site/assets/js/main.js"></script>

                            @await RenderSectionAsync("Scripts", required: false)

                            <div id="cookieBanner" class="cookie-banner-box" style="display: none;">
                                <div class="container">
                                    <div class="row align-items-center">
                                        <div class="col-lg-9 cookie-content">
                                            <p>
                                                <i class="bi bi-info-circle-fill me-2"></i>
                                                SİTEMİZDE SİZE DAHA İYİ HİZMET VEREBİLMEK İÇİN ÇEREZLER KULLANILMAKTADIR.
                                                SİTEMİZİ KULLANMAYA DEVAM EDEREK ÇEREZ KULLANIMINI KABUL ETMİŞ SAYILIRSINIZ.
                                            </p>
                                        </div>
                                        <div class="col-lg-3 text-end mt-3 mt-lg-0">
                                            <button onclick="acceptCookies()" class="btn-cookie-accept">ANLADIM, KABUL ET</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <script>
                                    document.addEventListener("DOMContentLoaded", function () {
                                        // Kullanıcı daha önce kabul etmiş mi kontrol et aga
                                        if (!localStorage.getItem("cookiesAccepted")) {
                                            document.getElementById("cookieBanner").style.display = "block";
                                        }
                                    });

                                    function acceptCookies() {
                                        // Tercihi kaydet ve banner'ı kapat
                                        localStorage.setItem("cookiesAccepted", "true");
                                        document.getElementById("cookieBanner").style.display = "none";
                                    }
                            </script>
                        </body>

                    </html>