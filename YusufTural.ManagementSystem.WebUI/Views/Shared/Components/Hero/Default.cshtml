@model SiteInformation

<section id="hero" class="hero section dark-background">
    <img src="@(Model?.BigImageUrl ?? "/site/assets/img/arkaplan.png")" alt="" data-aos="fade-in">
    
    <div class="container d-flex flex-column align-items-center text-center">
        <h2 data-aos="fade-up" data-aos-delay="100">@Model?.Slogan.ToUpper()</h2>
        <p data-aos="fade-up" data-aos-delay="200">@Model?.SloganDescription.ToUpper()</p>
        
        <div class="d-flex flex-column flex-md-row gap-3 mt-4 w-100 align-items-center justify-content-center" data-aos="fade-up" data-aos-delay="300">
            
            <a href="https://wa.me/9@(ViewBag.WpNumber)" class="btn-whatsapp-hero">
                <i class="bi bi-whatsapp"></i> <span>WHATSAPP'TAN SİPARİŞ VER</span>
            </a>

            <a href="#services" class="btn-services-hero">
                <i class="bi bi-droplet-fill"></i><span>HİZMETLERİMİZİ GÖR</span>
            </a>

            @if (!string.IsNullOrEmpty(Model?.VideoUrl))
            {
                <a href="@Model.VideoUrl" class="glightbox btn-watch-video d-flex align-items-center">
                    <i class="bi bi-play-circle"></i><span>TANITIM VİDEOSU</span>
                </a>
            }
        </div>
    </div>
</section>