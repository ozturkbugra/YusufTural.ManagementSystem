@model List<Vehicle>

<section id="portfolio" class="portfolio section">

    <div class="container section-title" data-aos="fade-up">
        <h2>ARAÇLARIMIZ</h2>
        <p>HİZMETİMİZDE KULLANDIĞIMIZ TAM DONANIMLI TANKERİMİZ</p>
    </div>

    <div class="container">
        <div class="row gy-4" data-aos="fade-up" data-aos-delay="200">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 portfolio-item">
                    <div class="portfolio-content h-100">
                        <img src="@item.ImageUrl" class="img-fluid" alt="@item.Description">
                        <div class="portfolio-info">
                            <h4>ARAÇLARIMIZ</h4>
                            <p>@item.Description.ToUpper()</p>
                            <a href="@item.ImageUrl" title="@item.Description.ToUpper()" data-gallery="portfolio-gallery" class="glightbox preview-link">
                                <i class="bi bi-zoom-in"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>

</section>