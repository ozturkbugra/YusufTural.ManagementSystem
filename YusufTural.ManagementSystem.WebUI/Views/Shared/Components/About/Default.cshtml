@model AboutUs
<section id="about" class="about section">
    <div class="container" data-aos="fade-up">
        <div class="row gy-4 align-items-center">
            <div class="col-lg-6"><img src="@Model?.ImageUrl" class="img-fluid rounded-4" alt="Hakkımızda"></div>
            <div class="col-lg-6">
                <div class="content ps-0 ps-lg-5">
                    <h3>HAKKIMIZDA</h3>
                    <p>@Html.Raw(Model?.Description.ToUpper())</p>
                </div>
            </div>
        </div>
    </div>
</section>