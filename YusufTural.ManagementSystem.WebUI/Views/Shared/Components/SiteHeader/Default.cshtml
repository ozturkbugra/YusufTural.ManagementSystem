@model SiteInformation
@{
    var services = ViewBag.Services as List<Service>;
}

<header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container-fluid container-xl position-relative d-flex align-items-center">

        <a href="/" class="logo d-flex align-items-center me-auto">
            @if (!string.IsNullOrEmpty(Model?.Logo))
            {
                <img src="@Model.Logo" alt="@Model.Name">
            }
            <h1 class="sitename">@(Model?.Name ?? "YUSUF TURAL")</h1>
        </a>

        <nav id="navmenu" class="navmenu">
            <ul>
                <li><a href="/#hero" class="active">ANA SAYFA</a></li>
                <li><a href="/#about">HAKKIMIZDA</a></li>
                <li class="dropdown">
                    <a href="/#services"><span>HİZMETLERİMİZ</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                    <ul>
                        @foreach (var item in services ?? new List<Service>())
                        {
                            <li><a asp-controller="Service" asp-action="Detail" asp-route-id="@item.Id">@item.Title.ToUpper()</a></li>
                        }
                    </ul>
                </li>
                <li><a href="/#portfolio">ARAÇLARIMIZ</a></li>
                <li><a href="/#faq">SSS</a></li>
                <li><a href="/#contact">İLETİŞİM</a></li>
            </ul>
            <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

        @if (ViewBag.Contact is Contact contact && !string.IsNullOrEmpty(contact.WhatsAppNumber))
        {
            <a href="https://wa.me/@contact.WhatsAppNumber.Replace(" ", "")" class="whatsapp-float" target="_blank">
                <i class="bi bi-whatsapp"></i>
            </a>
        }

    </div>
</header>