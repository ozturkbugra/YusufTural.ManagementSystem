@model SiteInformation
@{
    var contact = ViewBag.Contact as Contact;
    var services = ViewBag.Services as List<Service>;
}

<footer id="footer" class="footer dark-background">
    <div class="container footer-top">
        <div class="row gy-4">

            <div class="col-lg-4 col-md-6 footer-about">
                <a href="/" class="logo d-flex align-items-center">
                    <span class="sitename">@Model?.Name</span>
                </a>
                <div class="footer-contact pt-3">
                    <p>@contact?.Address</p>
                    <p class="mt-3"><strong>TELEFON:</strong> <span>@contact?.PhoneNumber</span></p>
                    <p><strong>E-POSTA:</strong> <span>@contact?.Email</span></p>
                </div>
                <div class="social-links d-flex mt-4">
                    @if (!string.IsNullOrEmpty(contact?.WhatsAppNumber))
                    {
                        <a href="https://wa.me/@contact.WhatsAppNumber.Replace(" ", "")"><i class="bi bi-whatsapp"></i></a>
                    }
                    @if (!string.IsNullOrEmpty(contact?.InstagramLink))
                    {
                        <a href="@contact.InstagramLink"><i class="bi bi-instagram"></i></a>
                    }
                </div>
            </div>

            <div class="col-lg-2 col-md-3 footer-links">
                <h4>HIZLI MENÜ</h4>
                <ul>
                    <li><i class="bi bi-chevron-right"></i> <a href="/#hero">ANA SAYFA</a></li>
                    <li><i class="bi bi-chevron-right"></i> <a href="/#about">HAKKIMIZDA</a></li>
                    <li><i class="bi bi-chevron-right"></i> <a href="/#services">HİZMETLERİMİZ</a></li>
                    <li><i class="bi bi-chevron-right"></i> <a href="/#contact">İLETİŞİM</a></li>
                </ul>
            </div>

            <div class="col-lg-2 col-md-3 footer-links">
                <h4>HİZMETLERİMİZ</h4>
                <ul>
                    @foreach (var item in (services ?? new List<Service>()).Take(5))
                    {
                        <li><i class="bi bi-chevron-right"></i> <a asp-controller="Service" asp-action="Detail" asp-route-id="@item.Id">@item.Title.ToUpper()</a></li>
                    }
                </ul>
            </div>

            <div class="col-lg-4 col-md-12 footer-newsletter">
                <h4>7/24 KESİNTİSİZ HİZMET</h4>
                <p>@Model?.SloganDescription</p>
                <p><strong>ÇALIŞMA SAATLERİ:</strong> @contact?.WorkingHours</p>
                <div class="mt-3">
                    <i class="bi bi-truck" style="font-size: 2rem; color: #00d2ff;"></i>
                    <span class="ms-2">HIZLI VE GÜVENLİ TESLİMAT</span>
                </div>
            </div>

        </div>
    </div>

    <div class="container copyright text-center mt-4">
        <p>© <span>COPYRIGHT</span> <strong class="px-1 sitename">@Model?.Name</strong> <span>TÜM HAKLARI SAKLIDIR</span></p>
    </div>
</footer>