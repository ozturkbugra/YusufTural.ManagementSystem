@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Sayfa Bulunamadı | Yusuf Tural</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a; /* Karanlık profesyonel arka plan */
            color: #f8fafc;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .error-container {
            text-align: center;
            padding: 2rem;
        }

        .error-code {
            font-size: clamp(8rem, 20vw, 12rem);
            font-weight: 800;
            line-height: 1;
            background: linear-gradient(to bottom, #38bdf8, #0ea5e9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
            position: relative;
        }

        .error-code::after {
            content: "404";
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            filter: blur(40px);
            opacity: 0.3;
            z-index: -1;
            color: #0ea5e9;
        }

        .error-title {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #94a3b8;
            margin-bottom: 2rem;
        }

        .error-description {
            max-width: 500px;
            margin: 0 auto 3rem;
            color: #64748b;
            font-size: 1.1rem;
        }

        .btn-group-custom {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-custom {
            padding: 0.8rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-transform: uppercase;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

        .btn-home { background: #0ea5e9; color: white; border: none; }
        .btn-home:hover { background: #0284c7; transform: translateY(-3px); color: white; }

        .btn-services { background: rgba(255, 255, 255, 0.05); color: #f8fafc; border: 1px solid rgba(255, 255, 255, 0.1); }
        .btn-services:hover { background: rgba(255, 255, 255, 0.1); transform: translateY(-3px); color: white; }

        .btn-contact { background: #10b981; color: white; border: none; }
        .btn-contact:hover { background: #059669; transform: translateY(-3px); color: white; }

        /* Su damlası animasyonu (İnce bir dokunuş) */
        .water-drop {
            position: absolute;
            bottom: -20px;
            left: 50%;
            transform: translateX(-50%);
            animation: drip 2s infinite;
            color: #38bdf8;
            font-size: 2rem;
            opacity: 0;
        }

        @@keyframes drip {
            0% { top: 0; opacity: 1; }
            70% { top: 100px; opacity: 1; }
            100% { top: 120px; opacity: 0; }
        }
    </style>
</head>
<body>

    <div class="error-container">
        <div class="error-code">404</div>
        <div class="error-title">Aradığınız Sayfa Bulunamadı</div>
        
        <p class="error-description">
            Aradığınız sayfa taşınmış veya kaldırılmış olabilir. <br class="d-none d-md-block" /> 
            Lütfen aşağıdaki butonları kullanarak doğru yola dönün.
        </p>

        <div class="btn-group-custom">
            <a href="/" class="btn-custom btn-home">
                <i class="bi bi-house"></i> ANA SAYFA
            </a>
            <a href="/#services" class="btn-custom btn-services">
                <i class="bi bi-truck"></i> HİZMETLERİMİZ
            </a>
            <a href="/#contact" class="btn-custom btn-contact">
                <i class="bi bi-whatsapp"></i> İLETİŞİME GEÇ
            </a>
        </div>
    </div>

</body>
</html>